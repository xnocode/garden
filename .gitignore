# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# ============================================
# Digital Garden — generated files (DO NOT UPLOAD)
# ============================================

# Database (generated by `bun run publish` — rebuilds on deploy)
/db/*.db
/db/*.db-journal

# Copied media assets (generated by `bun run publish` — rebuilds on deploy)
/public/content-assets/

# Upload/download folders (temporary files)
/upload/
/download/

# Obsidian workspace cache (if you open content/ in Obsidian)
/content/.obsidian/

# Build output
/.next/standalone/

# Tool results (temporary agent output)
/tool-results/

# Prisma generated client (regenerated on install)
node_modules/.prisma
